---
import { ArrowUpRight, Link2, Mail, Sparkles } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  FRIEND_CATEGORIES,
  FRIEND_EXCHANGE,
  FRIENDS,
  SITE,
  type FriendCategory
} from "@/consts";

const categories = (Object.keys(FRIEND_CATEGORIES) as FriendCategory[]).filter(
  (key) => FRIENDS.some((friend) => (friend.category ?? "other") === key)
);

const resolveAvatar = (url: string, avatar?: string) => {
  if (avatar) return avatar;
  try {
    return `https://icons.duckduckgo.com/ip3/${new URL(url).hostname}.ico`;
  } catch {
    return "/favicon.svg";
  }
};

const resolveHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
};

const friends = FRIENDS.map((friend) => {
  const category = friend.category ?? "other";
  return {
    ...friend,
    category,
    categoryLabel: FRIEND_CATEGORIES[category].label,
    avatarSrc: resolveAvatar(friend.url, friend.avatar),
    host: resolveHost(friend.url)
  };
});
---

<BaseLayout
  title="友链"
  description={`与 ${SITE.shortName} 互相连接的朋友与站点。`}
  theme="cyber"
>
  <section class="page-shell py-12">
    <!-- Page header — same rhythm as /blog /tags /archive -->
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-mint">Friends</p>
      <h1 class="mt-4 font-serif text-5xl font-bold tracking-normal text-zinc-950 dark:text-white">
        友链
      </h1>
      <p class="mt-5 text-lg leading-8 text-zinc-600 dark:text-zinc-300">
        一些值得反复点开的站点与朋友。互相看见，也互相留下路径。
      </p>
    </div>

    <!-- Stats strip -->
    <div class="mt-8 flex flex-wrap items-center gap-3 text-xs font-mono text-zinc-500 dark:text-zinc-400">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200/80 bg-white/70 px-3 py-1 dark:border-zinc-800 dark:bg-zinc-900/60">
        <Link2 class="size-3.5 text-mint" />
        {friends.length} LINKS
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-zinc-200/80 bg-white/70 px-3 py-1 dark:border-zinc-800 dark:bg-zinc-900/60">
        <Sparkles class="size-3.5 text-coral" />
        {categories.length} CATEGORIES
      </span>
    </div>

    <!-- Category filters -->
    {categories.length > 1 && (
      <div class="glass mt-8 flex flex-col gap-4 rounded-2xl p-4 sm:flex-row sm:items-center sm:justify-between">
        <span class="text-xs font-bold uppercase tracking-[0.1em] text-zinc-400">分类筛选</span>
        <div class="flex flex-wrap gap-1.5" id="friend-filters" role="group" aria-label="友链分类筛选">
          <button
            type="button"
            class="friend-filter-btn active focus-ring inline-flex items-center justify-center rounded-lg border border-zinc-200 bg-white px-3 py-1.5 text-xs font-semibold text-zinc-700 shadow-sm transition duration-200 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300"
            data-filter="all"
          >
            全部
          </button>
          {categories.map((key) => (
            <button
              type="button"
              class="friend-filter-btn focus-ring inline-flex items-center justify-center rounded-lg border border-transparent bg-zinc-100/50 px-3 py-1.5 text-xs font-semibold text-zinc-600 transition duration-200 hover:border-zinc-200 dark:bg-zinc-900/40 dark:text-zinc-400 dark:hover:border-zinc-800"
              data-filter={key}
            >
              {FRIEND_CATEGORIES[key].label}
            </button>
          ))}
        </div>
      </div>
    )}

    <!-- Friend cards -->
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" id="friends-grid">
      {friends.map((friend) => (
        <a
          class="friend-card group surface focus-ring relative flex flex-col overflow-hidden rounded-[8px] p-5 transition duration-300 hover:-translate-y-0.5 hover:border-mint/70 hover:shadow-md"
          href={friend.url}
          target="_blank"
          rel="noopener noreferrer"
          data-category={friend.category}
          aria-label={`${friend.name}（新窗口打开）`}
        >
          <div class="flex items-start gap-4">
            <span class="relative grid size-12 shrink-0 place-items-center overflow-hidden rounded-xl border border-zinc-200/80 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950">
              <img
                class="friend-avatar size-8 object-contain"
                src={friend.avatarSrc}
                alt=""
                loading="lazy"
                width="32"
                height="32"
                data-fallback="/favicon.svg"
              />
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-2">
                <h2 class="truncate font-serif text-xl font-bold text-zinc-950 transition group-hover:text-mint dark:text-white">
                  {friend.name}
                </h2>
                <ArrowUpRight class="mt-1 size-4 shrink-0 text-zinc-400 transition group-hover:text-mint" />
              </div>
              <p class="mt-1 truncate font-mono text-[11px] tracking-wide text-zinc-400">
                {friend.host}
              </p>
            </div>
          </div>

          <p class="mt-4 line-clamp-3 flex-1 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
            {friend.description}
          </p>

          <div class="mt-5 flex items-center justify-between border-t border-zinc-100 pt-4 dark:border-zinc-800/60">
            <span class="tag-chip px-2.5 py-0.5 text-[11px]">{friend.categoryLabel}</span>
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-zinc-400 transition group-hover:text-mint">
              open //
            </span>
          </div>
        </a>
      ))}
    </div>

    {friends.length === 0 && (
      <div class="surface mt-10 rounded-[8px] p-10 text-center">
        <p class="font-serif text-2xl font-bold text-zinc-950 dark:text-white">还没有友链</p>
        <p class="mt-3 text-sm text-zinc-500">在 <code class="text-mint">src/consts.ts</code> 的 <code class="text-mint">FRIENDS</code> 数组里添加即可。</p>
      </div>
    )}

    <!-- Exchange panel -->
    <aside class="cyber-terminal mt-14 overflow-hidden rounded-2xl p-6 sm:p-8">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_1fr] lg:items-start">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cy-cyan">// exchange protocol</p>
          <h2 class="mt-3 font-serif text-3xl font-bold text-zinc-950 dark:text-white">交换友链</h2>
          <p class="mt-4 max-w-xl text-sm leading-7 text-zinc-600 dark:text-zinc-300">
            欢迎独立博客与个人站点互换链接。请先添加本站，再通过邮件告知你的站点信息。
            优先通过内容真实、可长期访问的站点。
          </p>
          <ul class="mt-5 space-y-2 font-mono text-xs text-zinc-500 dark:text-zinc-400">
            <li><span class="text-mint">01</span> 站点可公网访问，无大量无效跳转</li>
            <li><span class="text-mint">02</span> 有原创内容或清晰的个人表达</li>
            <li><span class="text-mint">03</span> 先挂本站信息，再来申请</li>
          </ul>
          <a
            class="neon-btn neon-btn-cyan focus-ring mt-6 inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold"
            href={`mailto:${FRIEND_EXCHANGE.email}?subject=${encodeURIComponent(`友链申请 · ${SITE.shortName}`)}`}
          >
            <Mail class="size-4" />
            发送申请邮件
          </a>
        </div>

        <div class="surface rounded-[8px] p-5">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-zinc-400">本站信息</p>
          <div class="mt-4 flex items-center gap-3">
            <img
              class="size-12 rounded-xl border border-zinc-200 object-cover dark:border-zinc-800"
              src={FRIEND_EXCHANGE.avatar}
              alt=""
              width="48"
              height="48"
              loading="lazy"
            />
            <div class="min-w-0">
              <p class="truncate font-semibold text-zinc-950 dark:text-white">{FRIEND_EXCHANGE.name}</p>
              <p class="truncate font-mono text-[11px] text-mint">{FRIEND_EXCHANGE.url}</p>
            </div>
          </div>
          <p class="mt-4 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
            {FRIEND_EXCHANGE.description}
          </p>
          <dl class="mt-5 space-y-2 border-t border-zinc-100 pt-4 font-mono text-[11px] dark:border-zinc-800/60">
            <div class="flex justify-between gap-3">
              <dt class="text-zinc-400">NAME</dt>
              <dd class="text-right text-zinc-700 dark:text-zinc-200">{FRIEND_EXCHANGE.name}</dd>
            </div>
            <div class="flex justify-between gap-3">
              <dt class="text-zinc-400">URL</dt>
              <dd class="truncate text-right text-zinc-700 dark:text-zinc-200">{FRIEND_EXCHANGE.url}</dd>
            </div>
            <div class="flex justify-between gap-3">
              <dt class="text-zinc-400">MAIL</dt>
              <dd class="truncate text-right text-zinc-700 dark:text-zinc-200">{FRIEND_EXCHANGE.email}</dd>
            </div>
          </dl>
        </div>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .friend-filter-btn.active {
    border-color: rgba(15, 159, 143, 0.7);
    background-color: rgba(15, 159, 143, 0.05);
    color: #0f9f8f;
  }

  :global(.dark) .friend-filter-btn.active {
    background-color: rgba(15, 159, 143, 0.1);
    color: #0f9f8f;
  }

  .friend-card.filtered-out {
    display: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLImageElement>(".friend-avatar").forEach((img) => {
    img.addEventListener("error", () => {
      const fallback = img.dataset.fallback;
      if (fallback && img.src !== fallback) img.src = fallback;
    }, { once: true });
  });

  const buttons = document.querySelectorAll<HTMLButtonElement>(".friend-filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".friend-card");
  if (buttons.length && cards.length) {
    const idle =
      "border-transparent bg-zinc-100/50 text-zinc-600 dark:bg-zinc-900/40 dark:text-zinc-400";
    const active =
      "active border-zinc-200 bg-white shadow-sm dark:border-zinc-800 dark:bg-zinc-900";

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((item) => {
          item.className = `friend-filter-btn focus-ring inline-flex items-center justify-center rounded-lg border px-3 py-1.5 text-xs font-semibold transition duration-200 ${idle}`;
        });
        btn.className = `friend-filter-btn focus-ring inline-flex items-center justify-center rounded-lg border px-3 py-1.5 text-xs font-semibold transition duration-200 ${active}`;

        const filter = btn.dataset.filter ?? "all";
        cards.forEach((card) => {
          const category = card.dataset.category;
          card.classList.toggle("filtered-out", filter !== "all" && category !== filter);
        });
      });
    });
  }
</script>
