---
import { CalendarDays, Clock } from "@lucide/astro";
import { render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagPill from "@/components/TagPill.astro";
import { formatDate, getAllPosts, getReadingMinutes, type BlogPost } from "@/lib/posts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props as { post: BlogPost };
const { Content, headings } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover} theme="cyber-read">
  <article class="page-shell py-12">
    <header class="mx-auto max-w-3xl">
      <div class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => <TagPill name={tag} />)}
      </div>
      <h1 class="mt-6 font-serif text-4xl font-bold leading-tight tracking-normal text-zinc-950 dark:text-white sm:text-6xl">{post.data.title}</h1>
      <p class="mt-5 text-lg leading-8 text-zinc-600 dark:text-zinc-300">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-zinc-500">
        <span class="inline-flex items-center gap-1.5">
          <CalendarDays class="size-4" />
          {formatDate(post.data.pubDate)}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Clock class="size-4" />
          {getReadingMinutes(post)} 分钟
        </span>
      </div>
    </header>

    {post.data.cover && (
      <div class="mx-auto mt-10 max-w-5xl overflow-hidden rounded-[8px] border border-zinc-200 dark:border-zinc-800">
        <img class="h-[48vh] min-h-80 w-full object-cover" src={post.data.cover} alt="" />
      </div>
    )}

    <div class="mx-auto mt-10 grid max-w-5xl gap-10 lg:grid-cols-[minmax(0,1fr)_220px]">
      <div class="prose-blog">
        <Content />
      </div>

      {headings.length > 1 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24 border-l border-zinc-200 pl-5 dark:border-zinc-800">
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">目录</p>
            <nav class="mt-3 space-y-2">
              {headings.filter((heading) => heading.depth <= 3).map((heading) => (
                <a class="block text-sm leading-6 text-zinc-500 hover:text-mint" href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>
