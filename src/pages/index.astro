---
import { ArrowRight, ArrowDown, Terminal, Mail, PenLine } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, PROFILE } from "@/consts";
import { getAllPosts, formatDate, getReadingMinutes } from "@/lib/posts";

const posts = await getAllPosts();
const featured = posts.slice(0, 3);
const totalPosts = posts.length;
const allTags = posts.flatMap((p) => p.data.tags);
const totalTags = new Set(allTags).size;
const startDate = new Date(PROFILE.startedAt);
const today = new Date();
const runDays = Math.max(1, Math.ceil(Math.abs(today.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)));

const roles = [PROFILE.role, "实验员", "长期主义记录者", "技术实践者"];
const marquee = ["Astro", "TypeScript", "Tailwind", "Cloudflare", "React", "MDX", "Pagefind", "Keystatic", "Vite", "Shiki"];
const linuxDo = PROFILE.links.linuxDo;

const twPhrases = [
  "把想法做成工件，让它在迭代与连接中持续演进。",
  "记录技术实践、工具链、产品观察与长期问题。",
  "先写下来，再回头打磨，最后把它们连起来。"
];

const chapters = [
  {
    code: "DRAFT", title: "起草", body: "想法先写下来，哪怕粗糙。不追求一次写对，只求不被遗忘。在终端里敲一行、在便签上留一句，都算。",
    quote: "想法就像原型，先做出来，有的会迭代成稳定版本，有的就当作实验记录。"
  },
  {
    code: "ITER", title: "迭代", body: "回头打磨，补全上下文。把当时的为什么、踩过的坑、现在的修正都写进去，让一篇文章能够独立站住。",
    quote: "实验室不做一次性的输出，而是让想法在持续迭代里慢慢成型。"
  },
  {
    code: "LINK", title: "连接", body: "把相关想法连起来。双向链接、标签、归档都是路径，让后来的人——包括未来的自己——能从任意一个工件走到整间实验室。",
    quote: "最有趣的事发生在想法与想法的连接处。"
  }
];
---

<BaseLayout title={SITE.title} description={SITE.description} theme="cyber">

  <div class="cyber-scope page-shell relative">

    <!-- ============ HERO ============ -->
    <section class="relative flex min-h-[88vh] flex-col items-center justify-center py-24 text-center">
      <!-- Terminal prompt -->
      <div class="reveal font-mono text-xs text-cy-dim sm:text-sm">
        <span class="text-cy-magenta">root</span><span class="text-cy-dim">@</span><span class="text-cy-cyan">favere</span><span class="text-cy-dim">:~$ </span>
        <span class="text-cy-fg">./connect --lab</span>
        <span class="cyber-cursor">▋</span>
      </div>

      <!-- Glitch name -->
      <h1 class="reveal mt-8 font-mono text-6xl font-black uppercase tracking-tight sm:text-7xl md:text-8xl">
        <span class="glitch parallax-name" data-text={PROFILE.displayName}>{PROFILE.displayName}</span>
      </h1>

      <!-- Rotating role -->
      <div class="reveal mt-5 flex h-9 items-start justify-center overflow-hidden font-mono text-base text-cy-cyan sm:text-lg">
        <span class="sr-only">角色：</span>
        <span class="role-track flex flex-col items-center transition-transform duration-500" data-roles={JSON.stringify(roles)}>
          <span class="block h-9 leading-9">&gt; {roles[0]}</span>
        </span>
      </div>

      <!-- Typewriter tagline -->
      <p class="reveal typewriter mt-6 min-h-16 max-w-xl text-pretty text-base leading-8 text-cy-dim sm:text-lg" data-phrases={JSON.stringify(twPhrases)}>
        <span class="tw-text"></span><span class="tw-cursor cyber-cursor">▋</span>
      </p>

      <!-- CTAs -->
      <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="/lab/" class="neon-btn neon-btn-cyan group">
          <Terminal class="size-4" />
          进入实验室
          <ArrowRight class="size-4 transition-transform duration-300 group-hover:translate-x-0.5" />
        </a>
        <a href="/blog/" class="neon-btn neon-btn-magenta">
          <PenLine class="size-4" />
          读文章
        </a>
      </div>

      <!-- Scroll cue -->
      <a href="#stats" class="reveal absolute bottom-8 left-1/2 -translate-x-1/2 text-cy-cyan/60 transition hover:text-cy-cyan" aria-label="向下滚动">
        <ArrowDown class="size-5 animate-bounce" />
      </a>
    </section>

    <!-- ============ MARQUEE ============ -->
    <section class="reveal relative -mx-4 mb-4 overflow-hidden border-y border-cy-line/40 py-4 sm:-mx-6 lg:-mx-8" aria-hidden="true">
      <div class="marquee flex w-max whitespace-nowrap font-mono">
        {[...marquee, ...marquee].map((word) => (
          <span class="mr-8 inline-flex items-center gap-3 text-sm font-semibold tracking-wide text-cy-dim">
            <span class="text-cy-magenta">//</span>
            {word}
          </span>
        ))}
      </div>
    </section>

    <!-- ============ STATS ============ -->
    <section id="stats" class="grid grid-cols-3 gap-4 py-12">
      {[
        { value: totalPosts, label: "工件", unit: "POSTS" },
        { value: totalTags, label: "主题分类", unit: "TAGS" },
        { value: runDays, label: "运转天数", unit: "DAYS" }
      ].map((s, i) => (
        <div class="reveal hud-card rounded-xl p-6 text-center font-mono" style={`transition-delay: ${i * 80}ms`}>
          <div class="font-mono text-4xl font-black text-cy-cyan neon-cyan sm:text-5xl">{s.value}</div>
          <div class="mt-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-cy-dim">{s.label}</div>
          <div class="mt-1 text-[9px] text-cy-magenta/70">// {s.unit}</div>
        </div>
      ))}
    </section>

    <!-- ============ FEATURED ============ -->
    <section class="py-12">
      <div class="reveal mb-8 flex items-end justify-between">
        <div>
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-cy-magenta">// Featured</p>
          <h2 class="mt-2 font-mono text-3xl font-bold text-cy-fg sm:text-4xl">最近的工件</h2>
        </div>
        <a href="/blog/" class="group inline-flex items-center gap-1.5 font-mono text-sm font-semibold text-cy-dim transition hover:text-cy-cyan">
          查看全部
          <ArrowRight class="size-4 transition-transform duration-300 group-hover:translate-x-0.5" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {featured.map((post, i) => (
          <a
            href={`/blog/${post.id}/`}
            class="reveal cyber-card group relative flex flex-col overflow-hidden rounded-xl p-6"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="flex items-center justify-between font-mono text-[10px] text-cy-dim">
              <span class="inline-flex items-center gap-1 font-semibold uppercase tracking-wider">
                <PenLine class="size-3" />
                {formatDate(post.data.pubDate)}
              </span>
              <span class="text-cy-cyan/70">{getReadingMinutes(post)}m</span>
            </div>
            <h3 class="mt-4 font-mono text-xl font-bold leading-snug text-cy-fg transition group-hover:text-cy-cyan">
              {post.data.title}
            </h3>
            <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-cy-dim">
              {post.data.description}
            </p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="rounded-full border border-cy-line/50 px-2.5 py-0.5 font-mono text-[10px] font-medium text-cy-dim">
                  {tag}
                </span>
              ))}
            </div>
            <div class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs font-semibold text-cy-cyan opacity-0 transition duration-300 group-hover:opacity-100">
              阅读 <ArrowRight class="size-3.5" />
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ============ NARRATIVE / SCROLL STORY ============ -->
    <section class="py-16">
      <div class="reveal mb-12">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-cy-magenta">// Narrative</p>
        <h2 class="mt-2 font-mono text-3xl font-bold text-cy-fg sm:text-4xl">实验的三段</h2>
        <p class="mt-3 max-w-xl text-cy-dim">实验室不是一次性的输出，而是一个持续的过程。</p>
      </div>

      <div class="space-y-6">
        {chapters.map((c, i) => (
          <article class="chapter reveal grid gap-6 md:grid-cols-[0.9fr_1.1fr] md:items-start hud-card rounded-xl p-8" data-index={i}>
            <div class="md:sticky md:top-28">
              <div class="font-mono text-sm text-cy-magenta">0{i + 1} // {c.code}</div>
              <h3 class="mt-2 font-mono text-2xl font-bold text-cy-fg sm:text-3xl">{c.title}</h3>
              <p class="mt-4 leading-7 text-cy-dim">{c.body}</p>
            </div>
            <div class="hud-card rounded-lg p-5 font-mono text-xs leading-relaxed text-cy-dim">
              <div><span class="text-cy-magenta">$</span> <span class="text-cy-cyan/80">lab</span> --{c.code.toLowerCase()} <span class="text-cy-dim">#{(i + 1).toString().padStart(4, "0")}</span></div>
              <div class="mt-2 text-cy-cyan/70">+ status: growing</div>
              <div class="mt-3 border-l-2 border-cy-magenta/60 pl-3 text-cy-fg/90">"{c.quote}"</div>
              <div class="mt-3 text-cy-dim">links: <span class="text-cy-cyan">proto</span> → <span class="text-cy-cyan">iter</span> → <span class="text-cy-cyan">stable</span></div>
              <div class="mt-2 flex items-center gap-2">
                <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cy-cyan"></span>
                <span class="text-cy-dim">tracking growth…</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ============ CTA / CONTACT ============ -->
    <section class="py-16">
      <div class="reveal cyber-terminal relative overflow-hidden rounded-2xl p-10 text-center sm:p-16">
        <div class="font-mono text-xs text-cy-magenta">// establish_connection</div>
        <h2 class="mt-4 font-mono text-3xl font-bold text-cy-fg sm:text-4xl">一起把想法做出来</h2>
        <p class="mx-auto mt-4 max-w-md text-pretty leading-7 text-cy-dim">
          欢迎来信交流技术、产品或长期主义的话题，或在 GitHub 上看看别的小实验。
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href={`mailto:${SITE.email}`} class="neon-btn neon-btn-cyan">
            <Mail class="size-4" />
            来信
          </a>
          <a href={SITE.github} class="neon-btn neon-btn-magenta" aria-label="GitHub">
            <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.137 20.164 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
            </svg>
            GitHub
          </a>
          {linuxDo && (
            <a href={linuxDo.href} title={linuxDo.title} class="neon-btn neon-btn-ghost">
              <img src={linuxDo.icon} alt="" class="size-4 rounded-sm" />
              {linuxDo.title}
            </a>
          )}
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ---------- Scroll reveal (generic) ----------
  const revealEls = document.querySelectorAll<HTMLElement>(".reveal");
  if (revealEls.length) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );
    revealEls.forEach((el) => io.observe(el));
  }

  // ---------- Narrative chapter reveal (staggered) ----------
  const chapters = document.querySelectorAll<HTMLElement>(".chapter");
  if (chapters.length) {
    const cio = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            cio.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.2, rootMargin: "0px 0px -15% 0px" }
    );
    chapters.forEach((el) => cio.observe(el));
  }

  // ---------- Rotating roles ----------
  const roleTrack = document.querySelector<HTMLElement>(".role-track");
  const roles: string[] = roleTrack ? JSON.parse(roleTrack.dataset.roles || "[]") : [];
  if (roleTrack && roles.length > 1 && !prefersReduced) {
    let idx = 0;
    roleTrack.innerHTML = roles
      .map((r) => `<span class="block h-9 leading-9">&gt; ${r}</span>`)
      .join("");
    roleTrack.style.transform = "translateY(0)";
    const step = () => {
      idx = (idx + 1) % roles.length;
      roleTrack.style.transform = `translateY(-${idx * 2.25}rem)`;
    };
    let timer = setInterval(step, 2600);
    document.addEventListener("visibilitychange", () => {
      clearInterval(timer);
      if (!document.hidden) timer = setInterval(step, 2600);
    });
  }

  // ---------- Typewriter ----------
  const tw = document.querySelector<HTMLElement>(".typewriter");
  const twText = tw?.querySelector<HTMLElement>(".tw-text");
  const phrases: string[] = tw ? JSON.parse(tw.dataset.phrases || "[]") : [];
  if (twText && phrases.length) {
    if (prefersReduced) {
      twText.textContent = phrases[0];
    } else {
      let pi = 0, ci = 0, deleting = false;
      const tick = () => {
        const cur = phrases[pi];
        if (!deleting) {
          ci++;
          twText.textContent = cur.slice(0, ci);
          if (ci === cur.length) {
            deleting = true;
            setTimeout(tick, 1800);
            return;
          }
          setTimeout(tick, 45 + Math.random() * 45);
        } else {
          ci--;
          twText.textContent = cur.slice(0, ci);
          if (ci === 0) {
            deleting = false;
            pi = (pi + 1) % phrases.length;
            setTimeout(tick, 350);
            return;
          }
          setTimeout(tick, 22);
        }
      };
      setTimeout(tick, 700);
    }
  }
</script>
