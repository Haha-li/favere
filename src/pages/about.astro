---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/consts";
---

<BaseLayout title="关于" description={`关于 ${SITE.title}。`}>
  <section class="page-shell grid gap-10 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-mint">About</p>
      <h1 class="mt-4 font-serif text-5xl font-bold tracking-normal text-zinc-950 dark:text-white">关于这个博客</h1>
      <p class="mt-5 text-lg leading-8 text-zinc-600 dark:text-zinc-300">
        {SITE.title} 用来沉淀技术实践、工具链、产品观察和生活里的长期问题。
      </p>
    </div>

    <div class="space-y-5">
      <section class="border-b border-zinc-200 pb-5 dark:border-zinc-800">
        <h2 class="font-serif text-2xl font-bold text-zinc-950 dark:text-white">写什么</h2>
        <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">技术踩坑、架构选择、自动化工作流、部署记录、阅读笔记和阶段复盘。</p>
      </section>
      <section class="border-b border-zinc-200 pb-5 dark:border-zinc-800">
        <h2 class="font-serif text-2xl font-bold text-zinc-950 dark:text-white">怎么维护</h2>
        <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">先以 Markdown/MDX 为内容源，保持轻量</p>
      </section>
      <!-- <section>
        <h2 class="font-serif text-2xl font-bold text-zinc-950 dark:text-white">联系方式</h2>
        <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
          可以通过 <a class="font-semibold text-mint hover:underline" href={`mailto:${SITE.email}`}>{SITE.email}</a> 联系。
        </p>
      </section> -->
    </div>
  </section>
</BaseLayout>

