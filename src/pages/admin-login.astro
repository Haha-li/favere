---
import { ArrowRight, KeyRound, LockKeyhole, ShieldCheck } from '@lucide/astro';
import {
  ADMIN_AUTH_COOKIE,
  getAdminAuthConfig,
  normalizeAdminNextPath,
  verifyAdminSession,
} from '@/lib/admin-auth';
import '@/styles/global.css';

export const prerender = false;

const next = normalizeAdminNextPath(Astro.url.searchParams.get('next'));
const error = Astro.url.searchParams.get('error');
const loggedOut = Astro.url.searchParams.get('logged_out') === '1';
const config = getAdminAuthConfig(Astro.locals);
const sessionCookie = Astro.cookies.get(ADMIN_AUTH_COOKIE)?.value;

if (await verifyAdminSession(sessionCookie, config)) {
  return Astro.redirect(next);
}

const message =
  error === 'missing-config'
    ? '后台密码还没有配置。请先设置 KEYSTATIC_ADMIN_PASSWORD。'
    : error === 'invalid'
      ? '密码不正确，请重新输入。'
      : loggedOut
        ? '你已经退出后台。'
        : '';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>后台登录 | Favere Notes</title>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="min-h-screen bg-[#fafafa] text-zinc-950 antialiased dark:bg-zinc-950 dark:text-zinc-50">
    <main class="relative grid min-h-screen overflow-hidden px-5 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(360px,0.95fr)] lg:px-12">
      <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(24,24,27,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(24,24,27,0.08)_1px,transparent_1px)] bg-[size:48px_48px] dark:bg-[linear-gradient(rgba(255,255,255,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.08)_1px,transparent_1px)]"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(15,159,143,0.22),transparent_32%),radial-gradient(circle_at_78%_22%,rgba(228,93,72,0.16),transparent_30%),linear-gradient(135deg,rgba(255,255,255,0.9),rgba(250,250,250,0.66))] dark:bg-[radial-gradient(circle_at_18%_18%,rgba(15,159,143,0.18),transparent_32%),radial-gradient(circle_at_78%_22%,rgba(228,93,72,0.15),transparent_30%),linear-gradient(135deg,rgba(9,9,11,0.86),rgba(24,24,27,0.78))]"></div>

      <section class="relative z-10 flex min-h-[38vh] flex-col justify-between py-4 lg:min-h-full lg:py-8">
        <a
          href="/"
          class="focus-ring inline-flex w-fit items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-zinc-700 no-underline transition-colors hover:text-mint dark:text-zinc-300"
        >
          Favere Notes
        </a>

        <div class="max-w-2xl py-14 lg:py-0">
          <div class="mb-7 inline-flex items-center gap-2 border border-zinc-300 bg-white/72 px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-600 backdrop-blur dark:border-zinc-700 dark:bg-zinc-900/70 dark:text-zinc-300">
            <ShieldCheck class="size-4 text-mint" aria-hidden="true" />
            Private CMS Gate
          </div>
          <h1 class="max-w-xl text-5xl font-semibold leading-[0.96] tracking-normal text-zinc-950 dark:text-white sm:text-6xl lg:text-7xl">
            内容宇宙的入口，只给作者打开。
          </h1>
          <p class="mt-7 max-w-lg text-base leading-8 text-zinc-600 dark:text-zinc-300">
            这里会先验证管理员会话，再进入 Keystatic。公开博客继续保持开放，后台页面和后台 API 会被一起拦住。
          </p>
        </div>

        <div class="grid max-w-xl gap-3 text-sm text-zinc-600 dark:text-zinc-400 sm:grid-cols-3">
          <span class="border-t border-zinc-300 pt-3 dark:border-zinc-700">HttpOnly cookie</span>
          <span class="border-t border-zinc-300 pt-3 dark:border-zinc-700">Signed session</span>
          <span class="border-t border-zinc-300 pt-3 dark:border-zinc-700">Keystatic guarded</span>
        </div>
      </section>

      <section class="relative z-10 flex items-center justify-center lg:justify-end">
        <div class="w-full max-w-[440px] border border-zinc-200 bg-white/86 p-6 shadow-[0_24px_80px_rgba(24,24,27,0.16)] backdrop-blur-xl dark:border-zinc-800 dark:bg-zinc-900/82 sm:p-8">
          <div class="mb-7 flex items-start justify-between gap-5">
            <div>
              <p class="text-sm font-medium text-zinc-500 dark:text-zinc-400">Admin Login</p>
              <h2 class="mt-2 text-2xl font-semibold text-zinc-950 dark:text-white">进入后台</h2>
            </div>
            <div class="grid size-11 place-items-center border border-zinc-200 bg-zinc-50 text-zinc-800 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-100">
              <LockKeyhole class="size-5" aria-hidden="true" />
            </div>
          </div>

          {
            message && (
              <p
                class:list={[
                  'mb-5 border px-4 py-3 text-sm leading-6',
                  error === 'invalid' || error === 'missing-config'
                    ? 'border-coral/35 bg-coral/10 text-coral dark:text-red-200'
                    : 'border-mint/30 bg-mint/10 text-mint dark:text-emerald-200',
                ]}
              >
                {message}
              </p>
            )
          }

          <form action="/api/admin-auth/login" method="post" class="space-y-5">
            <input type="hidden" name="next" value={next} />
            <label class="block" for="password">
              <span class="mb-2 block text-sm font-medium text-zinc-700 dark:text-zinc-200">管理员密码</span>
              <span class="relative block">
                <KeyRound class="pointer-events-none absolute left-4 top-1/2 size-4 -translate-y-1/2 text-zinc-400" aria-hidden="true" />
                <input
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="current-password"
                  required
                  autofocus
                  class="focus-ring h-12 w-full border border-zinc-300 bg-white pl-11 pr-4 text-base text-zinc-950 outline-none transition-colors placeholder:text-zinc-400 hover:border-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-white dark:hover:border-zinc-500"
                  placeholder="输入后台密码"
                />
              </span>
            </label>

            <button
              type="submit"
              class="focus-ring inline-flex h-12 w-full cursor-pointer items-center justify-center gap-2 bg-zinc-950 px-5 text-sm font-semibold text-white transition-colors duration-200 hover:bg-mint dark:bg-white dark:text-zinc-950 dark:hover:bg-mint dark:hover:text-white"
            >
              进入 Keystatic
              <ArrowRight class="size-4" aria-hidden="true" />
            </button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
