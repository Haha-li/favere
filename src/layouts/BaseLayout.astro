---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import CyberBackground from "@/components/CyberBackground.astro";
import ScrollProgress from "@/components/ScrollProgress.astro";
import CommandPalette from "@/components/CommandPalette.astro";
import { SITE } from "@/consts";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  theme?: "paper" | "cyber" | "cyber-read";
}

const {
  title = SITE.title,
  description = SITE.description,
  image = "https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=1600&q=80",
  theme = "paper"
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const isCyber = theme === "cyber" || theme === "cyber-read";
const cyberVariant = theme === "cyber-read" ? "read" : "full";
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <title>{pageTitle}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      // Dark is the site default; only an explicit "light" choice opts out.
      if (storedTheme !== "light") {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class:list={[
    "relative overflow-x-hidden min-h-screen antialiased",
    isCyber
      ? "cyber bg-[var(--cy-bg)] text-[var(--cy-fg)]"
      : "bg-paper bg-dot-grid text-zinc-950 dark:bg-zinc-950 dark:text-zinc-50"
  ]}>
    {
      isCyber ? (
        <CyberBackground variant={cyberVariant} />
      ) : (
        <>
          <div class="absolute top-[10%] left-[20%] -translate-x-1/2 -translate-y-1/2 size-[500px] rounded-full bg-mint/20 blur-[120px] dark:bg-mint/12 pointer-events-none z-0" aria-hidden="true"></div>
          <div class="absolute bottom-[20%] right-[10%] translate-x-1/2 translate-y-1/2 size-[650px] rounded-full bg-coral/18 blur-[140px] dark:bg-coral/12 pointer-events-none z-0" aria-hidden="true"></div>
          <div class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 size-[750px] rounded-full bg-skyline/15 blur-[165px] dark:bg-skyline/10 pointer-events-none z-0" aria-hidden="true"></div>
        </>
      )
    }

    <div class:list={["relative z-10 flex flex-col min-h-screen", isCyber ? "cyber-scope" : ""]}>
      <ScrollProgress />
      <Header />
      <main id="main-content" class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>
    <CommandPalette />
  </body>
</html>
