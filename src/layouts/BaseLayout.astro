---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/consts";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = "https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=1600&q=80"
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <title>{pageTitle}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (storedTheme === "dark" || (!storedTheme && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="relative overflow-x-hidden min-h-screen bg-paper bg-dot-grid text-zinc-950 antialiased dark:bg-zinc-950 dark:text-zinc-50">
    <!-- Global Aurora Glowing Blobs in Background -->
    <div class="absolute top-[10%] left-[20%] -translate-x-1/2 -translate-y-1/2 size-[500px] rounded-full bg-mint/20 blur-[120px] dark:bg-mint/12 pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute bottom-[20%] right-[10%] translate-x-1/2 translate-y-1/2 size-[650px] rounded-full bg-coral/18 blur-[140px] dark:bg-coral/12 pointer-events-none z-0" aria-hidden="true"></div>
    <div class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 size-[750px] rounded-full bg-skyline/15 blur-[165px] dark:bg-skyline/10 pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />
      <main id="main-content" class="flex-grow">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
