---
import { Sparkles, Tag } from "@lucide/astro";
import { PROFILE } from "@/consts";
import type { BlogPost } from "@/lib/posts";
import { getTags } from "@/lib/posts";

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;

// Calculate stats
const totalPosts = posts.length;
const allTags = getTags(posts);
const totalTags = allTags.length;

// Dynamically calculate days running since May 20, 2026
const startDate = new Date(PROFILE.startedAt);
const today = new Date();
const diffTime = Math.abs(today.getTime() - startDate.getTime());
const runDays = Math.max(1, Math.ceil(diffTime / (1000 * 60 * 60 * 24)));

const stickyNotes = [
  {
    tone: "sticky-note-yellow",
    position: "left-2 top-8 z-10 w-[72%] rotate-[-2.5deg]",
    pin: "bg-red-400 border-red-500",
    meta: "text-amber-800/60 dark:text-amber-200/40",
    text: "想法就像原型，先做出来，有的会迭代成稳定版本，有的就当作实验记录。最重要的是把它做出来。",
    label: "本地备用"
  },
  {
    tone: "sticky-note-mint",
    position: "right-2 top-24 z-20 w-[68%] rotate-[3.5deg]",
    pin: "bg-emerald-400 border-emerald-500",
    meta: "text-emerald-800/60 dark:text-emerald-200/40",
    text: "实验室的特点：不做一次性的输出，而是让想法在迭代与连接中持续演进。",
    label: "本地备用"
  },
  {
    tone: "sticky-note-coral",
    position: "left-4 top-44 z-30 w-[64%] rotate-[-1.5deg]",
    pin: "bg-rose-400 border-rose-500",
    meta: "text-rose-800/60 dark:text-rose-200/40",
    text: "本周迭代进度：重构了全站排版布局，明亮主题的暖白纸感极度舒适。",
    label: "本地备用"
  }
];
---

<!-- Lab ID Badge -->
<div class="glass relative overflow-hidden rounded-2xl p-6 transition duration-300 hover:shadow-md hover:border-zinc-300 dark:hover:border-zinc-700">
  <div class="absolute top-0 right-0 h-20 w-20 bg-gradient-to-bl from-mint/10 to-transparent rounded-bl-full"></div>
  
  <!-- Header -->
  <div class="flex items-center justify-between border-b border-zinc-200/60 pb-4 dark:border-zinc-800/60">
    <div class="flex items-center gap-2">
      <div class="h-2 w-2 rounded-full bg-mint animate-pulse"></div>
      <span class="text-[10px] font-bold tracking-[0.2em] text-zinc-400 dark:text-zinc-500 uppercase">Lab Pass</span>
    </div>
    <span class="text-[10px] font-mono text-zinc-400 dark:text-zinc-500">ID: {PROFILE.badgeId}</span>
  </div>

  <!-- Badge Content -->
  <div class="mt-5 flex gap-4">
    <!-- Avatar with border decoration -->
    <div class="relative size-16 shrink-0 rounded-lg border-2 border-mint/20 p-0.5 dark:border-mint/30">
      <img
        class="size-full rounded object-cover"
        src={PROFILE.avatarUrl}
        alt={`${PROFILE.displayName} avatar`}
      />
      <div class="absolute -bottom-1 -right-1 rounded-full bg-mint p-0.5 text-white">
        <Sparkles class="size-2.5" />
      </div>
    </div>

    <!-- Details -->
    <div class="flex flex-col justify-center">
      <h3 class="font-serif text-lg font-bold text-zinc-950 dark:text-white">{PROFILE.displayName}</h3>
      <p class="text-xs text-zinc-500 dark:text-zinc-400">{PROFILE.role}</p>
      <div class="mt-2 flex items-center gap-1.5 text-[10px] text-mint font-semibold bg-mint/5 dark:bg-mint/10 px-2 py-0.5 rounded-full w-fit">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-mint opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-mint"></span>
        </span>
        {PROFILE.statusText}
      </div>
    </div>
  </div>

  <!-- Barcode decoration representing high-end badge -->
  <div class="mt-5 flex items-center justify-between gap-4">
    <div class="flex flex-col gap-1">
      <div class="flex gap-1">
        <a
          href={PROFILE.links.linuxDo.href}
          class="focus-ring rounded-[4px] transition hover:opacity-80"
          aria-label="Linux.do 主页"
          title={PROFILE.links.linuxDo.title}
          target="_blank"
          rel="noreferrer"
        >
          <img class="size-4 rounded-[3px]" src={PROFILE.links.linuxDo.icon} alt="" />
        </a>
      </div>
    </div>
    <!-- Simple Barcode styling using CSS stripes -->
    <div class="flex h-6 items-end gap-[1.5px] opacity-20 dark:opacity-40" aria-hidden="true">
      <div class="w-[2px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[1px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[3px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[1px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[4px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[2px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[1px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[3px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[1px] h-full bg-zinc-950 dark:bg-white"></div>
      <div class="w-[2px] h-full bg-zinc-950 dark:bg-white"></div>
    </div>
  </div>
</div>

<!-- Stats Card -->
<div class="glass grid grid-cols-3 divide-x divide-zinc-200/60 rounded-2xl p-5 text-center dark:divide-zinc-800/60">
  <div class="flex flex-col justify-center">
    <span class="text-2xl font-bold font-serif text-zinc-900 dark:text-white">{totalPosts}</span>
    <span class="mt-1 text-[10px] tracking-[0.1em] text-zinc-400 uppercase">工件</span>
  </div>
  <div class="flex flex-col justify-center">
    <span class="text-2xl font-bold font-serif text-zinc-900 dark:text-white">{totalTags}</span>
    <span class="mt-1 text-[10px] tracking-[0.1em] text-zinc-400 uppercase">主题分类</span>
  </div>
  <div class="flex flex-col justify-center">
    <span class="text-2xl font-bold font-serif text-zinc-900 dark:text-white">{runDays}</span>
    <span class="mt-1 text-[10px] tracking-[0.1em] text-zinc-400 uppercase">运转天数</span>
  </div>
</div>

<!-- Sticky Notes Board -->
<div class="relative min-h-[290px] w-full p-2">
  <!-- Pushpin / Header -->
  <div class="mb-4 flex items-center gap-1.5">
    <span class="text-xs font-bold tracking-[0.15em] text-zinc-400 dark:text-zinc-500 uppercase">实验日志 Board</span>
  </div>

  {
    stickyNotes.map((note, index) => (
      <div
        class:list={[note.tone, "absolute rounded-md p-4", note.position]}
        data-hitokoto-note={index}
      >
        <div class:list={["absolute top-2 left-1/2 -translate-x-1/2 size-2.5 rounded-full shadow-sm border", note.pin]} aria-hidden="true"></div>
        <p
          class="mt-1 font-serif text-xs leading-relaxed"
          data-hitokoto-text={index}
        >
          "{note.text}"
        </p>
        <a
          class:list={["mt-3 block text-right text-[9px] transition hover:underline", note.meta]}
          href="https://hitokoto.cn"
          target="_blank"
          rel="noreferrer"
          data-hitokoto-source={index}
        >
          {note.label}
        </a>
      </div>
    ))
  }
</div>

<script>
  type HitokotoApiResponse = {
    hitokoto?: unknown;
    from?: unknown;
    from_who?: unknown;
    uuid?: unknown;
  };

  type HitokotoNote = {
    text: string;
    label: string;
    href: string;
  };

  const hitokotoCategories = ["d", "i", "k"];

  const buildHitokotoUrl = (index: string, attempt: number) => {
    const categoryIndex = Number.parseInt(index, 10);
    const category = hitokotoCategories[categoryIndex % hitokotoCategories.length] ?? "d";
    const url = new URL("https://v1.hitokoto.cn/");

    url.searchParams.set("c", category);
    url.searchParams.set("min_length", "8");
    url.searchParams.set("max_length", "42");
    url.searchParams.set("encode", "json");
    url.searchParams.set("_", `${Date.now()}-${index}-${attempt}-${Math.random().toString(36).slice(2)}`);

    return url.toString();
  };

  const normalizeHitokoto = (data: HitokotoApiResponse): HitokotoNote | null => {
    const text = typeof data.hitokoto === "string" ? data.hitokoto.trim() : "";

    if (!text) return null;

    const source = typeof data.from === "string" && data.from.trim() ? data.from.trim() : "一言";
    const author =
      typeof data.from_who === "string" && data.from_who.trim() ? data.from_who.trim() : "";
    const uuid = typeof data.uuid === "string" ? data.uuid : "";

    return {
      text,
      label: author ? `${author} · ${source}` : `一言 · ${source}`,
      href: uuid ? `https://hitokoto.cn?uuid=${encodeURIComponent(uuid)}` : "https://hitokoto.cn"
    };
  };

  const fetchHitokoto = async (index: string, attempt: number): Promise<HitokotoNote | null> => {
    const controller = new AbortController();
    const timeoutId = window.setTimeout(() => controller.abort(), 4200);

    try {
      const response = await fetch(buildHitokotoUrl(index, attempt), {
        cache: "no-store",
        signal: controller.signal
      });

      if (!response.ok) return null;

      return normalizeHitokoto((await response.json()) as HitokotoApiResponse);
    } finally {
      window.clearTimeout(timeoutId);
    }
  };

  const fetchUniqueHitokoto = async (
    index: string,
    seenTexts: Set<string>
  ): Promise<HitokotoNote | null> => {
    for (let attempt = 0; attempt < 4; attempt += 1) {
      const note = await fetchHitokoto(index, attempt);

      if (!note || seenTexts.has(note.text)) continue;

      seenTexts.add(note.text);
      return note;
    }

    return null;
  };

  const renderHitokoto = (index: string, note: HitokotoNote) => {
    const text = document.querySelector<HTMLElement>(`[data-hitokoto-text="${index}"]`);
    const source = document.querySelector<HTMLAnchorElement>(`[data-hitokoto-source="${index}"]`);

    if (!text || !source) return;

    text.textContent = `"${note.text}"`;
    source.textContent = note.label;
    source.setAttribute("href", note.href);
  };

  const hydrateHitokotoNotes = async () => {
    const noteElements = [...document.querySelectorAll<HTMLElement>("[data-hitokoto-note]")];
    const seenTexts = new Set<string>();

    for (const element of noteElements) {
      const index = element.dataset.hitokotoNote;
      if (typeof index !== "string") continue;

      const note = await fetchUniqueHitokoto(index, seenTexts);
      if (!note) continue;

      renderHitokoto(index, note);
    }
  };

  const scheduleHitokotoNote = () => {
    window.setTimeout(hydrateHitokotoNotes, 200);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleHitokotoNote, { once: true });
  } else {
    scheduleHitokotoNote();
  }
</script>

<!-- Topics Explorer Card -->
<div class="glass relative overflow-hidden rounded-2xl p-5">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-1.5">
      <Tag class="size-4 text-mint" />
      <span class="text-xs font-bold tracking-[0.15em] text-zinc-400 dark:text-zinc-500 uppercase">浏览主题 Topics</span>
    </div>
    <span class="text-[10px] font-semibold text-mint bg-mint/5 px-2 py-0.5 rounded-full dark:bg-mint/10">
      共 {totalTags} 个分类
    </span>
  </div>

  <div class="flex flex-wrap gap-2.5 mt-2">
    {allTags.map((tag, index) => {
      const colors = [
        "border-emerald-200 bg-emerald-50/40 text-emerald-700 dark:border-emerald-900/30 dark:bg-emerald-950/10 dark:text-emerald-300 hover:border-emerald-400 dark:hover:border-emerald-700",
        "border-rose-200 bg-rose-50/40 text-rose-700 dark:border-rose-900/30 dark:bg-rose-950/10 dark:text-rose-300 hover:border-rose-400 dark:hover:border-rose-700",
        "border-sky-200 bg-sky-50/40 text-sky-700 dark:border-sky-900/30 dark:bg-sky-950/10 dark:text-sky-300 hover:border-sky-400 dark:hover:border-sky-700",
        "border-amber-200 bg-amber-50/40 text-amber-700 dark:border-amber-900/30 dark:bg-amber-950/10 dark:text-amber-300 hover:border-amber-400 dark:hover:border-amber-700",
        "border-violet-200 bg-violet-50/40 text-violet-700 dark:border-violet-900/30 dark:bg-violet-950/10 dark:text-violet-300 hover:border-violet-400 dark:hover:border-violet-700"
      ];
      const colorClass = colors[index % colors.length];
      
      const badgeColors = [
        "bg-emerald-600/10 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-300",
        "bg-rose-600/10 text-rose-700 dark:bg-rose-500/20 dark:text-rose-300",
        "bg-sky-600/10 text-sky-700 dark:bg-sky-500/20 dark:text-sky-300",
        "bg-amber-600/10 text-amber-700 dark:bg-amber-500/20 dark:text-amber-300",
        "bg-violet-600/10 text-violet-700 dark:bg-violet-500/20 dark:text-violet-300"
      ];
      const badgeClass = badgeColors[index % badgeColors.length];

      return (
        <a 
          href={`/tags/${encodeURIComponent(tag.name)}/`}
          class:list={[
            "inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 text-xs font-semibold shadow-sm transition duration-300 hover:-translate-y-0.5 cursor-pointer",
            colorClass
          ]}
        >
          <span>{tag.name}</span>
          <span class:list={[
            "flex size-4.5 items-center justify-center rounded-full text-[9px] font-bold",
            badgeClass
          ]}>
            {tag.count}
          </span>
        </a>
      )
    })}
  </div>
</div>
