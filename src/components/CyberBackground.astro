---
interface Props {
  variant?: "full" | "read";
}
const { variant = "full" } = Astro.props;
const isRead = variant === "read";
---

<div class="cyber-bg" aria-hidden="true" data-variant={variant}>
  {!isRead && <canvas id="cyber-canvas"></canvas>}
  <div class="cyber-grid-floor" data-static={isRead ? "true" : "false"}></div>
  {!isRead && <div class="cyber-scanlines"></div>}
  <div class="cyber-vignette"></div>
</div>

<script>
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const bg = document.querySelector<HTMLElement>(".cyber-bg");
  const variant = bg?.dataset.variant ?? "full";
  const root = document.documentElement;

  const LOW_POWER_BREAKPOINT = 768;
  const LOW_POWER_CORE_LIMIT = 4;
  const MAX_PARTICLES = 56;
  const LOW_POWER_PARTICLES = 32;
  const MIN_PARTICLES = 24;
  const PARTICLE_DENSITY = 26000;
  const MAX_DPR = 1.25;
  const LOW_POWER_DPR = 1;
  const TARGET_FPS = 30;
  const LOW_POWER_FPS = 20;
  const BASE_FRAME_MS = 1000 / 60;
  const CONNECTION_DISTANCE = 116;
  const PARALLAX_DISTANCE = 24;
  const VIEWPORT_MARGIN = "120px";
  const DEFAULT_CORE_COUNT = 8;
  const POINTER_SCALE = 2;
  const POINTER_OFFSET = 1;
  const PARTICLE_DEPTH_RANGE = 0.8;
  const PARTICLE_MIN_DEPTH = 0.2;
  const PARTICLE_VELOCITY_RANGE = 0.18;
  const CYAN_PARTICLE_RATIO = 0.72;
  const CONNECTION_ALPHA = 0.13;
  const CONNECTION_LINE_WIDTH = 0.6;
  const PARTICLE_RADIUS_SCALE = 1.9;
  const PARTICLE_GLOW_SCALE = 2.8;
  const PARTICLE_GLOW_ALPHA = 0.12;
  const PARTICLE_CORE_ALPHA = 0.85;
  const PARTICLE_EDGE_PADDING = 10;
  const MAX_FRAME_DELTA = 2;
  const FULL_CIRCLE = Math.PI * 2;

  const lowPower =
    window.innerWidth <= LOW_POWER_BREAKPOINT ||
    (navigator.hardwareConcurrency ?? DEFAULT_CORE_COUNT) <= LOW_POWER_CORE_LIMIT;

  let pointerX = 0;
  let pointerY = 0;
  let pointerRaf = 0;

  // 单一指针监听：同时服务网格视差与 Canvas，避免重复 mousemove 工作。
  if (!prefersReduced) {
    window.addEventListener("pointermove", (event) => {
      pointerX = (event.clientX / window.innerWidth) * POINTER_SCALE - POINTER_OFFSET;
      pointerY = (event.clientY / window.innerHeight) * POINTER_SCALE - POINTER_OFFSET;
      if (pointerRaf) return;
      pointerRaf = requestAnimationFrame(() => {
        root.style.setProperty("--mx", pointerX.toFixed(3));
        root.style.setProperty("--my", pointerY.toFixed(3));
        pointerRaf = 0;
      });
    }, { passive: true });
  }

  type Particle = {
    x: number;
    y: number;
    z: number;
    vx: number;
    vy: number;
    c: "cyan" | "magenta";
  };

  type ProjectedParticle = {
    px: number;
    py: number;
    particle: Particle;
  };

  class ParticleNetwork {
    private readonly particles: Particle[] = [];
    private readonly particleLimit: number;
    private readonly maxDpr: number;
    private readonly frameInterval: number;
    private width = 0;
    private height = 0;
    private raf = 0;
    private lastFrame = 0;
    private activeInViewport = true;
    private cyanRgb = "0, 240, 255";
    private magentaRgb = "255, 45, 149";

    constructor(
      private readonly canvas: HTMLCanvasElement,
      private readonly ctx: CanvasRenderingContext2D
    ) {
      this.particleLimit = lowPower ? LOW_POWER_PARTICLES : MAX_PARTICLES;
      this.maxDpr = lowPower ? LOW_POWER_DPR : MAX_DPR;
      this.frameInterval = 1000 / (lowPower ? LOW_POWER_FPS : TARGET_FPS);
    }

    initialize() {
      this.readColors();
      this.resize();
      this.bindLifecycle();
      this.start();
    }

    private readColors() {
      const styles = getComputedStyle(root);
      this.cyanRgb = styles.getPropertyValue("--cy-cyan-rgb").trim() || this.cyanRgb;
      this.magentaRgb = styles.getPropertyValue("--cy-magenta-rgb").trim() || this.magentaRgb;
    }

    private createParticle(): Particle {
      return {
        x: Math.random() * this.width,
        y: Math.random() * this.height,
        z: Math.random() * PARTICLE_DEPTH_RANGE + PARTICLE_MIN_DEPTH,
        vx: (Math.random() - 0.5) * PARTICLE_VELOCITY_RANGE,
        vy: (Math.random() - 0.5) * PARTICLE_VELOCITY_RANGE,
        c: Math.random() < CYAN_PARTICLE_RATIO ? "cyan" : "magenta"
      };
    }

    private projectParticles(): ProjectedParticle[] {
      return this.particles.map((particle) => ({
        px: particle.x + pointerX * PARALLAX_DISTANCE * particle.z,
        py: particle.y + pointerY * PARALLAX_DISTANCE * particle.z,
        particle
      }));
    }

    private drawConnections(points: ProjectedParticle[]) {
      for (let i = 0; i < points.length; i++) {
        for (let j = i + 1; j < points.length; j++) {
          const first = points[i];
          const second = points[j];
          const distance = Math.hypot(first.px - second.px, first.py - second.py);
          if (distance >= CONNECTION_DISTANCE) continue;
          const alpha = CONNECTION_ALPHA * (1 - distance / CONNECTION_DISTANCE);
          this.ctx.strokeStyle = `rgba(${this.cyanRgb},${alpha})`;
          this.ctx.lineWidth = CONNECTION_LINE_WIDTH;
          this.ctx.beginPath();
          this.ctx.moveTo(first.px, first.py);
          this.ctx.lineTo(second.px, second.py);
          this.ctx.stroke();
        }
      }
    }

    private drawParticles(points: ProjectedParticle[]) {
      for (const { px, py, particle } of points) {
        const radius = particle.z * PARTICLE_RADIUS_SCALE;
        const rgb = particle.c === "cyan" ? this.cyanRgb : this.magentaRgb;
        this.ctx.beginPath();
        this.ctx.arc(px, py, radius * PARTICLE_GLOW_SCALE, 0, FULL_CIRCLE);
        this.ctx.fillStyle = `rgba(${rgb},${PARTICLE_GLOW_ALPHA})`;
        this.ctx.fill();
        this.ctx.beginPath();
        this.ctx.arc(px, py, radius, 0, FULL_CIRCLE);
        this.ctx.fillStyle = `rgba(${rgb},${PARTICLE_CORE_ALPHA})`;
        this.ctx.fill();
      }
    }

    private draw() {
      this.ctx.clearRect(0, 0, this.width, this.height);
      const points = this.projectParticles();
      this.drawConnections(points);
      this.drawParticles(points);
    }

    private resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, this.maxDpr);
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.canvas.width = Math.floor(this.width * dpr);
      this.canvas.height = Math.floor(this.height * dpr);
      this.canvas.style.width = `${this.width}px`;
      this.canvas.style.height = `${this.height}px`;
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(
        this.particleLimit,
        Math.max(MIN_PARTICLES, Math.floor((this.width * this.height) / PARTICLE_DENSITY))
      );
      this.particles.length = 0;
      for (let i = 0; i < count; i++) this.particles.push(this.createParticle());
      this.draw();
    };

    private updateParticles(delta: number) {
      for (const particle of this.particles) {
        particle.x += particle.vx * delta;
        particle.y += particle.vy * delta;
        if (particle.x < -PARTICLE_EDGE_PADDING) particle.x = this.width + PARTICLE_EDGE_PADDING;
        else if (particle.x > this.width + PARTICLE_EDGE_PADDING) particle.x = -PARTICLE_EDGE_PADDING;
        if (particle.y < -PARTICLE_EDGE_PADDING) particle.y = this.height + PARTICLE_EDGE_PADDING;
        else if (particle.y > this.height + PARTICLE_EDGE_PADDING) particle.y = -PARTICLE_EDGE_PADDING;
      }
    }

    private loop = (now: number) => {
      this.raf = requestAnimationFrame(this.loop);
      if (!this.lastFrame) this.lastFrame = now;
      const elapsed = now - this.lastFrame;
      if (elapsed < this.frameInterval) return;
      this.lastFrame = now - (elapsed % this.frameInterval);
      this.updateParticles(Math.min(MAX_FRAME_DELTA, elapsed / BASE_FRAME_MS));
      this.draw();
    };

    private start() {
      if (!this.raf && this.activeInViewport && !document.hidden && !prefersReduced) {
        this.raf = requestAnimationFrame(this.loop);
      }
    }

    private stop() {
      if (this.raf) cancelAnimationFrame(this.raf);
      this.raf = 0;
      this.lastFrame = 0;
    }

    private bindLifecycle() {
      window.addEventListener("resize", this.resize, { passive: true });
      document.addEventListener("theme:change", () => {
        this.readColors();
        this.draw();
      });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) this.stop();
        else this.start();
      });
      const hero = document.getElementById("hero");
      if (!hero) return;
      new IntersectionObserver(([entry]) => {
        this.activeInViewport = entry.isIntersecting;
        if (this.activeInViewport) this.start();
        else this.stop();
      }, { rootMargin: VIEWPORT_MARGIN }).observe(hero);
    }
  }

  if (variant === "full") {
    const canvas = document.getElementById("cyber-canvas");
    const context = canvas instanceof HTMLCanvasElement ? canvas.getContext("2d") : null;
    if (canvas instanceof HTMLCanvasElement && context) {
      new ParticleNetwork(canvas, context).initialize();
    }
  }
</script>
