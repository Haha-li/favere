---
import { Moon, Sun } from "@lucide/astro";
---

<button
  id="theme-toggle"
  class="focus-ring rounded-full p-1.5 text-zinc-500 transition hover:bg-white hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white cursor-pointer"
  type="button"
  aria-label="切换颜色模式"
>
  <Sun class="size-4 dark:hidden" />
  <Moon class="hidden size-4 dark:block" />
</button>

<script>
  const button = document.querySelector<HTMLButtonElement>("#theme-toggle");

  button?.addEventListener("click", () => {
    const root = document.documentElement;
    const nextTheme = root.classList.toggle("dark") ? "dark" : "light";
    localStorage.setItem("theme", nextTheme);
  });
</script>
