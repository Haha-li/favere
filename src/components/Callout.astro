---
interface Props {
  title?: string;
  tone?: "note" | "idea";
}

const { title = "Note", tone = "note" } = Astro.props;

const styles = {
  note: "border-mint/30 bg-mint/10 text-zinc-800 dark:text-zinc-100",
  idea: "border-coral/30 bg-coral/10 text-zinc-800 dark:text-zinc-100"
};
---

<aside class:list={["my-6 rounded-[8px] border p-4", styles[tone]]}>
  <p class="m-0 text-sm font-semibold">{title}</p>
  <div class="mt-2 text-sm leading-6">
    <slot />
  </div>
</aside>
