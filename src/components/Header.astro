---
import { Rss, Search } from "@lucide/astro";
import { NAV_ITEMS, SITE } from "@/consts";
import ThemeToggle from "@/components/ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-3 z-50 mx-2 w-auto max-w-full rounded-[18px] border border-zinc-200/60 bg-white/80 p-2 px-4 shadow-md backdrop-blur-lg transition duration-300 dark:border-zinc-800/80 dark:bg-zinc-950/80 sm:top-5 sm:mx-auto sm:w-[calc(100%-2rem)] sm:max-w-[1440px] sm:px-8 md:rounded-full">
  <div class="flex min-h-11 items-center justify-between gap-4">
    <!-- Brand Logo -->
    <a class="focus-ring flex items-center gap-2 rounded-full" href="/" aria-label={SITE.title}>
      <span class="grid size-8 place-items-center rounded-full bg-zinc-950 text-xs font-black text-white dark:bg-white dark:text-zinc-950">{SITE.brandInitial}</span>
      <span class="text-xs font-semibold tracking-wide text-zinc-900 dark:text-zinc-100">{SITE.title}</span>
    </a>

    <!-- Desktop Nav Links -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="主导航">
      {NAV_ITEMS.map((item) => (
        <a
          class:list={[
            "focus-ring rounded-full px-3.5 py-1.5 text-xs font-semibold transition duration-200",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "bg-zinc-950 text-white dark:bg-white dark:text-zinc-950 shadow-sm"
              : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900 dark:hover:text-white"
          ]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right Utilities Capsule -->
    <div class="flex items-center gap-0.5 bg-zinc-100/60 dark:bg-zinc-900/50 p-0.5 rounded-full border border-zinc-200/30 dark:border-zinc-800/30">
      <a class="focus-ring rounded-full p-1.5 text-zinc-500 transition hover:bg-white hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white" href="/search/" aria-label="搜索">
        <Search class="size-4" />
      </a>
      <a class="focus-ring rounded-full p-1.5 text-zinc-500 transition hover:bg-white hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white" href="/rss.xml" aria-label="RSS">
        <Rss class="size-4" />
      </a>
      <ThemeToggle />
    </div>
  </div>

  <!-- Mobile Nav (Secondary Row inside capsule) -->
  <nav class="flex gap-1 overflow-x-auto pt-2 pb-1 border-t border-zinc-200/30 dark:border-zinc-800/40 md:hidden" aria-label="移动端导航">
    {NAV_ITEMS.map((item) => (
      <a
        class:list={[
          "focus-ring shrink-0 rounded-full px-3 py-1 text-xs font-semibold transition duration-200",
          currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
            ? "bg-zinc-950 text-white dark:bg-white dark:text-zinc-950"
            : "text-zinc-600 dark:text-zinc-300"
        ]}
        href={item.href}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>
